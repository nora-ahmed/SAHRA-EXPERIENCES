                <rightValue>
                    <numberValue>7.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Owner_and_Manager</targetReference>
            </connector>
            <label>7 Days</label>
        </rules>
        <rules>
            <name>X3_Days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Days_to_Event__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
