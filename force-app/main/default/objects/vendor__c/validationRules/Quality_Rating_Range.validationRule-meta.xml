<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quality_Rating_Range</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
    Quality_Rating__c &lt; 1,
    Quality_Rating__c &gt; 5
)</errorConditionFormula>
    <errorDisplayField>Quality_Rating__c</errorDisplayField>
    <errorMessage>Quality Rating must be between 1 and 5</errorMessage>
</ValidationRule>
